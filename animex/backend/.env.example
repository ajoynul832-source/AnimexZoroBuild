PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/animex
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
FRONTEND_URL=https://your-frontend.vercel.app
SITE_URL=https://your-frontend.vercel.app

# ─────────────────────────────────────────────────────────────────
# SCRAPER_URL — REQUIRED for video playback
# ─────────────────────────────────────────────────────────────────
# Deploy the /scraper folder as a SEPARATE Render web service.
# Then put that service's URL here (no trailing slash).
# Example: https://animex-scraper.onrender.com
SCRAPER_URL=https://YOUR-SCRAPER-SERVICE.onrender.com
